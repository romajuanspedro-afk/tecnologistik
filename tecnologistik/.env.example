# Variables de entorno para Railway
# Copia estos nombres y valores en Railway → Variables

# JWT - Genera un string aleatorio largo
JWT_SECRET=tu_jwt_secret_largo_y_aleatorio_min_32_caracteres

# Expiración del token JWT en milisegundos (1 hora = 3600000)
JWT_EXPIRATION_MS=3600000

# Gemini API - Obtén tu API key en: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_de_gemini

# CORS - URL del frontend en Vercel
CORS_ORIGINS=https://tu-frontend.vercel.app

# PostgreSQL - Railway lo agrega automáticamente:
# No necesitas configurarlos manualmente, pero si necesitas:
# DATABASE_URL=postgresql://user:password@host:5432/database
# PGUSER=postgres
# PGPASSWORD=password
# PGHOST=host
# PGPORT=5432
# PGDATABASE=database
